#!/usr/bin/env bash
# pre-commit hook - 提交前检查
# 检查: 协作者标识、敏感信息、测试产物、提交规范

set -eo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

HAS_ERROR=0
HAS_WARNING=0

info()  { echo -e "${GREEN}[OK]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!!]${NC} $1"; HAS_WARNING=1; }
error() { echo -e "${RED}[XX]${NC} $1"; HAS_ERROR=1; }

# 获取暂存文件列表
STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

# ============================================================
# 1. 检查协作者/AI 标识（排除 .githooks 目录自身）
# ============================================================
CHECKED_FILES=""
for f in $STAGED; do
    case "$f" in
        .githooks/*) continue ;;
    esac
    CHECKED_FILES="$CHECKED_FILES $f"
done

for file in $CHECKED_FILES; do
    if [ ! -f "$file" ]; then continue; fi
    if file "$file" | grep -q "text"; then
        if grep -qE "(Co-Authored-By|Generated with).*(Claude|Anthropic|Copilot)" "$file" 2>/dev/null; then
            error "$file 包含 AI 协作者标识"
        fi
    fi
done

# ============================================================
# 2. 检查敏感文件
# ============================================================
SENSITIVE_FILES=(
    ".env"
    ".env.local"
    ".env.production"
    ".env.development"
    "credentials.json"
    "service-account.json"
)

for file in $STAGED; do
    if [ ! -f "$file" ]; then continue; fi
    basename_file=$(basename "$file")

    for pattern in "${SENSITIVE_FILES[@]}"; do
        if [ "$basename_file" = "$pattern" ]; then
            error "检测到敏感文件: $file"
        fi
    done

    # 检查扩展名
    case "$basename_file" in
        *.pem|*.key) error "检测到密钥文件: $file" ;;
    esac

    # 检查文件内容 (仅文本文件)
    if file "$file" | grep -q "text"; then
        if grep -qE "-----BEGIN (RSA |EC )?PRIVATE KEY-----" "$file" 2>/dev/null; then
            error "$file 包含私钥"
        fi
        if grep -qE "(password|api_key|secret|token)\s*[:=]\s*[\"'][^\"']{8,}" "$file" 2>/dev/null; then
            error "$file 可能包含敏感凭证"
        fi
    fi
done

# ============================================================
# 3. 检查不应提交的产物
# ============================================================
for file in $STAGED; do
    case "$file" in
        dist/*|build/*|coverage/*|.nyc_output/*|__pycache__/*|.pytest_cache/*)
            warn "构建/测试产物不应提交: $file" ;;
        *.min.js|*.min.css|*.map)
            warn "压缩/映射文件不应提交: $file" ;;
        package-lock.json)
            warn "建议使用 bun.lock 替代: $file" ;;
    esac
done

# ============================================================
# 4. 检查大文件 (>1MB)
# ============================================================
for file in $STAGED; do
    if [ ! -f "$file" ]; then continue; fi
    size=$(wc -c < "$file" 2>/dev/null || echo "0")
    if [ "$size" -gt 1048576 ]; then
        warn "大文件 (>1MB): $file"
    fi
done

# ============================================================
# 结果
# ============================================================
echo ""
if [ "$HAS_ERROR" -gt 0 ]; then
    echo -e "${RED}提交检查失败，请修复上述问题${NC}"
    exit 1
elif [ "$HAS_WARNING" -gt 0 ]; then
    echo -e "${YELLOW}存在警告，请确认是否需要处理${NC}"
fi

info "提交检查通过"
exit 0
